# ────────────────────────────────────────────────────────────
# .dockerignore — Docker 빌드 컨텍스트에서 제외할 파일/디렉터리
#
# 빌드 컨텍스트가 작을수록 docker build 가 빠르고,
# 민감한 파일이 이미지에 포함되지 않는다.
# ────────────────────────────────────────────────────────────

# Gradle 캐시 및 빌드 산출물 (Dockerfile 내부에서 새로 빌드)
.gradle/
build/

# 환경 변수 파일 — 절대 이미지에 포함시키지 않는다
.env
.env.*
!.env.example

# 형상관리
.git/
.gitignore

# IDE / 에디터 설정
.idea/
*.iml
.vscode/
*.swp
*.swo

# OS 메타데이터
.DS_Store
Thumbs.db

# 테스트 리포트 (빌드 컨텍스트 불필요)
build/reports/
