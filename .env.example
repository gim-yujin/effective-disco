# ────────────────────────────────────────────────────────────
# .env.example — 환경 변수 템플릿
#
# 사용법:
#   cp .env.example .env
#   .env 파일을 열어 각 값을 실제 값으로 교체한다.
#   .env 는 .gitignore에 포함되어 있으므로 저장소에 커밋되지 않는다.
# ────────────────────────────────────────────────────────────

# ── 데이터베이스 ──────────────────────────────────────────
# PostgreSQL 접속 비밀번호 (필수 — 빈 값 사용 금지)
DB_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────
# 256비트(32바이트) 이상의 무작위 문자열을 사용할 것.
# 생성 예: openssl rand -hex 32
JWT_SECRET=change_me_at_least_32_characters_long_secret_key

# 토큰 유효 시간 (밀리초). 기본값: 86400000 = 24시간
JWT_EXPIRATION=86400000

# ── 애플리케이션 ──────────────────────────────────────────
# 호스트에서 바인딩할 포트 (기본값: 8080)
APP_PORT=8080

# JVM 힙 옵션 (기본값: -Xmx512m)
JAVA_OPTS=-Xmx512m
